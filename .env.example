# Resend API Key for sending emails
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# Sender email address - must be from a verified domain in your Resend dashboard.
# Until tuscindia.com is verified, leave this unset to use Resend's onboarding@resend.dev
# (note: onboarding@resend.dev can only send to the Resend account owner's email).
# Once verified, set this to: noreply@tuscindia.com
RESEND_FROM_EMAIL=noreply@tuscindia.com

# Recipient email address for contact form submissions
RESEND_TO_EMAIL=hello@tuscindia.com
